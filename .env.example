# Copy to .env and fill in real values. Never commit .env.
POSTGRES_DB=ontrack
POSTGRES_USER=ontrack
POSTGRES_PASSWORD=change-me
APP_VERSION=dev
# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me
# Public origin the app is served from (magic links point here)
APP_URL=https://ontrack.eremann.de
# Resend API key — empty = ConsoleMailer (links only appear in api logs, no email)
RESEND_API_KEY=
# Sender address; must be on a Resend-verified domain to email arbitrary recipients
EMAIL_FROM=OnTrack <no-reply@eremann.de>
# Cloudflare Tunnel token for ontrack.eremann.de (docker compose --profile tunnel)
TUNNEL_TOKEN=
